<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Footer Animation</title>
  <style>
    body {
      margin: 0;
      padding: 0;
    }

    footer {
      position: fixed;
      bottom: 0;
      width: 100%;
      /* border-top: 2px solid #333; */
     background: linear-gradient(to right, #3f51b5, #2196f3, #00bcd4);
      overflow: hidden;
      height: 40px;
       box-shadow: 0 -3px 10px rgba(0, 0, 0, 0.3);
    }

    .scrolling-text {
      white-space: nowrap;
      display: inline-block;
      padding-left: 100%;
      animation: scroll-left 15s linear infinite;
      font-family: Arial, sans-serif;
      font-size: 16px;
      color: #fff;
    }

    @keyframes scroll-left {
      0% {
        transform: translateX(0%);
      }
      100% {
        transform: translateX(-100%);
      }
    }
  </style>
</head>
<body>

  <!-- Your page content -->

  <footer>
    <div class="scrolling-text">Powered by IT Center / BBSR / HQ</div>
  </footer>

</body>
</html>
