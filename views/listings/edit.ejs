<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Appointments & Meetings</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <style>
    * {
      box-sizing: border-box;
    }

    body {
      font-family: Arial, sans-serif;
      margin: 0;
      background: linear-gradient(to bottom, #dbe9ff, #f2f7fc);
    }

    .container {
      max-width: 900px;
      margin: 40px  auto;
      background-color: white;
      border-radius: 15px;
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.15);
      overflow: hidden;
    }

    .title-section {
      text-align: center;
      background-color: #007bff;
      padding: 0;
      color: white;
      margin-bottom: 0;
      /* border-bottom: 3px solid #007bff; */
    }

    .title-section h2 {
      margin: 0;
  padding: 15px 0; /* Apply padding directly to h2 for spacing */
  font-size: 22px;
  color: white;
  text-align: center;
  border-top-left-radius: 15px;
  border-top-right-radius: 15px;
    }

    form {
      padding: 30px;
      display: flex;
      flex-wrap: wrap;
      gap: 20px;
    }

    .form-group {
      flex: 1 1 calc(50% - 20px);
      display: flex;
      flex-direction: column;
    }

    .form-group-full {
      flex: 1 1 100%;
    }

    label {
      font-weight: bold;
      margin-bottom: 5px;
      color: #003366;
    }

    input[type="text"],
    input[type="date"],
    input[type="time"],
    textarea {
      padding: 10px;
      font-size: 16px;
      border: 2px solid #007bff;
      border-left: 5px solid red;
      border-radius: 5px;
      background-color: #f9faff;
    }

    textarea {
      resize: vertical;
    }

    .checkbox-wrapper {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-top: 35px;
    }

    .checkbox-wrapper label {
      margin: 0;
      font-weight: bold;
      color: #003366;
    }

    .venue-vip-row {
      display: flex;
      gap: 20px;
      flex-wrap: nowrap;
      align-items: center;
    }

    .venue-vip-row .form-group {
      flex: 1 1 70%;
      margin-bottom: 0;
    }

    .venue-vip-row .checkbox-wrapper {
    flex: 1 1 30%;
    margin-top: 0;
    display: flex;
    align-items: center;
    gap: 10px;
}

    .btn-group {
      display: flex;
      justify-content: flex-end;
      margin-top: 20px;
    }

    .btn-group button {
      padding: 10px 20px;
      font-size: 14px;
      background-color: #003366;
      color: white;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      width: 9rem;
    }

    .btn-group button:hover {
      background-color: #001f4d;
    }

    @media (max-width: 768px) {
      .form-group {
        flex: 1 1 100%;
      }

      .venue-vip-row {
        flex-direction: column;
      }

      .checkbox-wrapper {
        margin-top: 10px;
      }

      .btn-group {
        justify-content: center;
      }
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="title-section">
      <h2>Appointments & Meetings</h2>
    </div>
    <form action="/edit/<%= meeting._id %>" method="POST">
      <div class="form-group">
        <label for="meetingDate">Appointment / Meeting Date:</label>
        <input type="date" id="meetingDate" name="meetingDate" value="<%= meeting.meetingDate.toISOString().split('T')[0] %>" required />
      </div>

      <div class="form-group">
        <label for="meetingTime">Appointment / Meeting Time:</label>
        <input type="time" id="meetingTime" name="meetingTime" value="<%= meeting.meetingTime %>" required />
      </div>

      <div class="form-group">
        <label for="meetingWith">Appointment / Meeting With:</label>
        <input type="text" id="meetingWith" name="meetingWith" value="<%= meeting.meetingWith %>" required />
      </div>

      <div class="form-group">
        <label for="designation">Designation:</label>
        <input type="text" id="designation" name="designation" value="<%= meeting.designation %>" required />
      </div>

      <div class="form-group form-group-full">
        <label for="purpose">Purpose:</label>
        <textarea id="purpose" name="purpose" rows="3" required><%= meeting.purpose %></textarea>
      </div>

      <div class="venue-vip-row">
        <div class="form-group">
          <label for="venue">Venue:</label>
          <input type="text" id="venue" name="venue" value="<%= meeting.venue %>" required />
        </div>
        <div class="checkbox-wrapper">
          <input type="checkbox" id="isVIP" name="isVIP" <%= meeting.isVIP ? 'checked' : '' %> />
          <label for="isVIP">Is VIP?</label>
        </div>
      </div>

      <div class="form-group form-group-full btn-group">
        <button type="submit">SUBMIT</button>
      </div>
    </form>
  </div>
</body>
</html>
