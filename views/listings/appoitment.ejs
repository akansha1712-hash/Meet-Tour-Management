<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Appointments & Meetings</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    * { box-sizing: border-box; }
    body {
      font-family: Arial, sans-serif;
      background: linear-gradient(to right, #c9d6ff, #e2e2e2);
      margin: 0;
      padding: 0;
    }

    .container {
      max-width: 98%;
      margin: 40px auto 20px auto;
      padding: 20px;
      background: #f9fbfd;
      border-radius: 8px;
      border: 2px solid #003366;
      overflow-x: auto;
    }

    .top-header {
      background-color: #1976d2;
      color: white;
      padding: 15px 20px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      border-radius: 6px 6px 0 0;
    }
  /* .top-header {
background: linear-gradient(to right, #1976d2, #42a5f5);
 padding: 15px 20px;
color: white;
border-radius: 8px 8px 0 0;
box-shadow: 0 0 20px rgba(0, 153, 255, 0.5);
}  */

.top-header:hover {
box-shadow: 0 0 20px rgba(0, 153, 255, 0.5);
transition: box-shadow 0.3s ease;
}
@keyframes slideInRow {
from {
opacity: 0;
 transform: translateY(20px);
 } to {
 opacity: 1;
 transform: translateY(0); }
}

.animate-row {
 animation: slideInRow 0.6s ease forwards;
}


    .top-header h1 {
      font-size: 24px;
      margin: 0;
      flex: 1 1 auto;
      text-align: center;
      
    }

    .top-header .btn-group {
      display: flex;
      gap: 10px;
      flex: 1 1 auto;
      justify-content: flex-end;
    }

    .top-header form button {
      padding: 8px 15px;
      border-radius: 4px;
      font-size: 14px;
      border: none;
      color: white;
      cursor: pointer;
    }

    .logout-btn { background-color: #dc3545; }
    .add-btn { background-color: #28a745; }

    .filter-form {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      align-items: center;
      gap: 10px;
      margin: 30px 0;
    }

    .filter-form label {
      font-weight: bold;
    }

    .filter-form input[type="date"],
    .filter-form button {
      padding: 10px;
      font-size: 16px;
      border-radius: 4px;
      border: 1px solid #ccc;
    }

    .filter-form button[type="submit"] {
      background-color: #007bff;
      color: white;
      border: none;
    }

    .filter-form button[type="reset"] {
      background-color: #6c757d;
      color: white;
      border: none;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 15px;
      background-color: #ffffff;
      border-radius: 10px;
      overflow: hidden;
      box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
    }

    th, td {
      padding: 14px 16px;
      text-align: center;
      border: none;
      white-space: nowrap;
    }

    th {
      background-color: #2196f3;
      color: white;
      font-weight: 600;
      letter-spacing: 0.5px;
    }

    tr:nth-child(odd) { background-color: #eef5ff; }
    tr:nth-child(even) { background-color: #e3f6f5; }

    tr:hover {
      background-color: #e0f7fa;
      transform: translateY(-2px) scale(1.005);
      transition: all 0.3s ease;
      box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
    }

    .edit-icon-btn {
      background: none;
      border: none;
      cursor: pointer;
      font-size: 20px;
      color: #007bff;
      transition: color 0.3s ease, transform 0.3s ease;
    }

    .edit-icon-btn:hover {
      color: #004a99;
      transform: scale(1.3);
    }

    .past-appointment { background-color: #f0f0f0 !important; }
    .today-appointment { background-color: #cce5ff !important; }
    .tomorrow-appointment { background-color: #fff9c4 !important; }

    .quick-note {
      padding: 6px;
      width: 180px;
      font-size: 14px;
      border-radius: 4px;
      border: 1px solid #ccc;
    }

    .note-submit-btn {
      padding: 6px 8px;
      margin-left: 4px;
      background-color: #28a745;
      color: white;
      border: none;
      border-radius: 4px;
      cursor: pointer;
    }

    .note-display {
      font-style: italic;
      font-size: 13px;
      color: #333;
      background: #ffffdd;
      padding: 4px 8px;
      border-radius: 5px;
    }

    @media (max-width: 768px) {
      .top-header {
        flex-direction: column;
        text-align: center;
      }
      .top-header .btn-group {
        justify-content: center;
      }
      .filter-form {
        flex-direction: column;
        align-items: stretch;
      }
      .filter-form button,
      .filter-form input[type="date"] {
        width: 100%;
      }
    }
.next-meeting-badge {
position: fixed;
top:20rem;
/* right:10px; */
background: linear-gradient(135deg, #00c6ff, #0072ff);
/* background-color: #dc3545; */
color: #fff;
padding: 10px 16px;
font-size: 13px;
font-weight: 600;
border-radius: 30px;
box-shadow: 0 0 12px rgba(0, 102, 255, 0.4);
z-index: 999;
display: flex;
align-items: center;
gap: 8px;
animation: pulseGlow 2s infinite;
transition: all 0.3s ease;
}

.next-meeting-badge:hover {
transform: scale(1.05);
box-shadow: 0 0 20px rgba(0, 102, 255, 0.6);
}

@keyframes pulseGlow {
   0% {
box-shadow: 0 0 10px rgba(0, 123, 255, 0.3);
}
50% {
box-shadow: 0 0 20px rgba(0, 123, 255, 0.6);
}
100% {
box-shadow: 0 0 10px rgba(0, 123, 255, 0.3);
}
}


@keyframes bounceIn {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.1);
  }
}

.add-btn {
animation: bounceIn 1.8s ease infinite;
}
@keyframes fadePage {
from { opacity: 0; }
to  { opacity: 1; }
}
body {
animation: fadePage 0.7s ease-in-out;
}




  </style>
</head>
<body>
  <div class="container">
    <div class="top-header">
      <h1>Appointments & Meetings</h1>
      <div class="btn-group">
        <% if (isLoggedIn) { %>
          <form action="/form" method="GET">
            <button class="add-btn" type="submit">+ Add New Appointment</button>
          </form>
          <form action="/logout" method="POST">
            <button class="logout-btn" type="submit">Logout</button>
          </form>
        <% } else { %>
          <form action="/home" method="GET">
            <button class="add-btn" type="submit">Login</button>
          </form>
        <% } %>
      </div>
    </div>

    <form class="filter-form" action="/appointments" method="GET">
      <label>From:</label>
      <input type="date" name="fromDate" required>
      <label>To:</label>
      <input type="date" name="toDate" required>
      <button type="submit">Show</button>
      <button type="reset">Clear</button>
    </form>
<% 
  const now = new Date();
  const upcomingMeeting = meetings.find(m => new Date(m.meetingDate) > now || 
    (new Date(m.meetingDate).toDateString() === now.toDateString() && m.meetingTime > now.toTimeString().slice(0, 5))
  );
%>

<% if (upcomingMeeting) { %>
 <div class="next-meeting-badge">
  <span>🕒</span>
  <span><strong>Next:</strong> <span id="countdown-timer">Calculating...</span></span>
</div>




  <script>
    const countdownDate = new Date("<%= upcomingMeeting.meetingDate.toISOString().split('T')[0] %> <%= upcomingMeeting.meetingTime %>").getTime();

    const x = setInterval(function() {
      const now = new Date().getTime();
      const distance = countdownDate - now;

      if (distance < 0) {
        clearInterval(x);
        document.getElementById("countdown-timer").innerText = "Meeting started";
        return;
      }

      const days = Math.floor(distance / (1000 * 60 * 60 * 24));
      const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
      const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
      const seconds = Math.floor((distance % (1000 * 60)) / 1000);

      document.getElementById("countdown-timer").innerText = 
        (days > 0 ? days + "d " : "") + 
        (hours > 0 ? hours + "h " : "") + 
        minutes + "m " + seconds + "s";
    }, 1000);
  </script>
<% } %>

    <% if (meetings && meetings.length > 0) { %>
      <table>
        <thead>
          <tr>
            <th>Date</th>
            <th>Time</th>
            <th>With</th>
            <th>Designation</th>
            <th>Purpose</th>
            <th>Venue</th>
            <th>VIP</th>
            <% if (isLoggedIn) { %>
              <th>Edit</th>
              <th>Quick Note</th>
            <% } %>
          </tr>
        </thead>
        <tbody>
          <% 
            const today = new Date();
            const tomorrow = new Date();
            tomorrow.setDate(today.getDate() + 1);

            meetings.forEach(meeting => {
              const meetingDate = new Date(meeting.meetingDate);
              let rowClass = '';
              let icon = '';

              if (meetingDate.toDateString() === today.toDateString()) {
                rowClass = 'today-appointment';
                icon = '✅';
              } else if (meetingDate.toDateString() === tomorrow.toDateString()) {
                rowClass = 'tomorrow-appointment';
                icon = '🔔';
              } else if (meetingDate < today) {
                rowClass = 'past-appointment';
                icon = '⏳';
              }
          %>
            <!-- <tr class="<%= rowClass %>"> -->
              <tr class="animate-row <%= rowClass %>">

              <td><%= meeting.meetingDate.toISOString().split('T')[0] %> <%= icon %></td>
              <td><%= meeting.meetingTime %></td>
              <td><%= meeting.meetingWith %></td>
              <td><%= meeting.designation %></td>
              <td><%= meeting.purpose %></td>
              <td><%= meeting.venue %></td>
              <td><%= meeting.isVIP ? '✔️' : '' %></td>
              <% if (isLoggedIn) { %>
                <td>
                  <form action="/edit/<%= meeting._id %>" method="GET">
                    <button type="submit" class="edit-icon-btn" title="Edit">
                      <i class="fas fa-pen-to-square"></i>
                    </button>
                  </form>
                </td>
                <td>
                  <% if (meetingDate < today) { %>
                    <form method="GET" action="/meetings/note/<%= meeting._id %>">
        <button class="note-submit-btn" type="submit" style="background-color:#1976d2;">✏️ View/Add Note</button>
</form>

                  <% } else { %>
                    <% if (meeting.quickNote) { %>
                      <div class="note-display"><%= meeting.quickNote %></div>
                    <% } else { %>
                      <em style="color: gray;">No note</em>
                    <% } %>
                  <% } %>
                </td>
              <% } %>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } else { %>
      <p style="text-align: center;">No meetings found for the selected date range.</p>
    <% } %>
  </div>
 <script>
document.addEventListener("DOMContentLoaded", function () {
  const resetButton = document.querySelector('button[type="reset"]');
  const table = document.querySelector("table");

  resetButton.addEventListener("click", function (e) {
    e.preventDefault(); // Prevent form reset submission

    const fromDate = document.querySelector('input[name="fromDate"]');
    const toDate = document.querySelector('input[name="toDate"]');

    if (fromDate) fromDate.value = '';
    if (toDate) toDate.value = '';
    if (table) table.style.display = "none";
  });
});
</script>

</body>
</html>


